{
  "name": "@namespacelabs/actions-toolkit",
  "version": "0.2.6",
  "description": "GitHub Actions toolkit for Namespace",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/namespacelabs/nscloud-actions-toolkit.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.6.2",
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./spacectl": {
      "types": "./dist/spacectl.d.mts",
      "import": "./dist/spacectl.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest",
    "test:run": "vitest run",
    "release": "./scripts/release.sh",
    "release:finalize": "./scripts/release-finalize.sh"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0",
    "@octokit/plugin-retry": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
